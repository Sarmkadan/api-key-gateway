{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ApiKeyGateway": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "RequireSsl": true,
    "LogAllRequests": true,
    "MaxKeyLength": 256,
    "MinKeyLength": 16,
    "DefaultKeyExpirationDays": 365,
    "AuditLogRetentionDays": 90,
    "EnableRateLimiting": true,
    "DefaultRateLimitPerHour": 10000,
    "MaxConcurrentRequests": 1000,
    "ClockSkewToleranceSeconds": 1.0,
    "WebhookMaxRetries": 3,
    "WebhookBaseDelayMs": 1000,
    "WebhookBackoffMultiplier": 2.0,
    "WebhookMaxDelayMs": 30000
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=ApiKeyGateway;Trusted_Connection=true;"
  }
}
